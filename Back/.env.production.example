NODE_ENV=production
PORT=3000
PUBLIC_API_URL=https://bego.com.ht
API_URL=https://bego.com.ht
CORS_ORIGINS=https://bego.com.ht,https://www.bego.com.ht,capacitor://localhost,http://localhost

MONGO_URI=mongodb://127.0.0.1:27017/bego
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change_me_long_random_secret
JWT_REFRESH_SECRET=change_me_long_random_refresh_secret
JWT_ACCESS_TTL=12h
PAYMENT_METHOD_ENCRYPTION_KEY=change_me_32_bytes_minimum_random_secret
AUTH_RATE_LIMIT_MAX=30
REGISTER_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_MAX=120
PHONE_VERIFICATION_SECRET=change_me_long_random_phone_secret
EMAIL_VERIFICATION_SECRET=change_me_long_random_email_secret
EMAIL_OTP_TTL_MINUTES=10
EMAIL_VERIFICATION_TOKEN_TTL=15m
EMAIL_OTP_COOLDOWN_SECONDS=60
EMAIL_OTP_HOURLY_LIMIT=5
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RATE_LIMIT_MAX=5
EMAIL_OTP_VERIFY_RATE_LIMIT_MAX=20
PHONE_OTP_TTL_MINUTES=10
PHONE_VERIFICATION_TOKEN_TTL=15m
PHONE_OTP_COOLDOWN_SECONDS=60
PHONE_OTP_HOURLY_LIMIT=5
PHONE_OTP_MAX_ATTEMPTS=5
PHONE_OTP_RATE_LIMIT_MAX=5
PHONE_OTP_VERIFY_RATE_LIMIT_MAX=20

# SMS para verificar telefonos al registrar
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=
# Solo desarrollo local. No activar en produccion.
PHONE_OTP_DEV_MODE=false

# Email por API HTTPS recomendado para produccion
EMAIL_PROVIDER=resend
EMAIL_FROM="BeGO <noreply@bego.com.ht>"
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com

# SMTP de respaldo
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_CONNECTION_TIMEOUT=15000
EMAIL_GREETING_TIMEOUT=15000
EMAIL_SOCKET_TIMEOUT=20000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OSRM_URL=http://127.0.0.1:5000
PAYMENT_BASE_URL=https://bego.com.ht/pagar
SOCKET_TRANSPORTS=websocket
MONCASH_PAYMENTS_ENABLED=false
MONCASH_API_BASE_URL=
MONCASH_CHECKOUT_URL=
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_SECRET=
NATCASH_PAYMENTS_ENABLED=false
NATCASH_API_BASE_URL=
NATCASH_CHECKOUT_URL=
NATCASH_API_KEY=
NATCASH_SECRET=
RECARGA_WALLET_MIN=50
RECARGA_WALLET_MAX=100000
ACTIVE_TRIP_TOKEN_GRACE_SECONDS=900

# Monitoreo y alertas
MONITOR_ALERT_EMAIL=
MONITOR_INTERVAL_MS=60000
MONITOR_WINDOW_MINUTES=5
MONITOR_PM2_RESTART_THRESHOLD=3
MONITOR_PM2_BAD_STATUS_CHECKS=2
MONITOR_SOCKET_DISCONNECT_THRESHOLD=80
MONITOR_SOCKET_INDIVIDUAL_ALERTS=false
MONITOR_FRONTEND_ERROR_THRESHOLD=12
MONITOR_ALERT_DEDUP_SECONDS=900
MONITOR_REDIS_TIMEOUT_MS=1500
FRONTEND_ERROR_RATE_LIMIT=40
CRITICAL_LOG_PATH=/var/log/bego/critical.log
MONITOR_STATE_FILE=/var/log/bego/monitor-state.json

BACKUP_DIR=/var/backups/bego
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_ENV=false
