NODE_ENV=production
PORT=3000
PUBLIC_API_URL=https://bego.com.ht
API_URL=https://bego.com.ht

MONGO_URI=mongodb://127.0.0.1:27017/bego
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change_me_long_random_secret
JWT_REFRESH_SECRET=change_me_long_random_refresh_secret

# Email por API HTTPS recomendado para produccion
EMAIL_PROVIDER=resend
EMAIL_FROM="BeGO <noreply@bego.com.ht>"
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com

# SMTP de respaldo
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_CONNECTION_TIMEOUT=15000
EMAIL_GREETING_TIMEOUT=15000
EMAIL_SOCKET_TIMEOUT=20000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OSRM_URL=http://127.0.0.1:5000
PAYMENT_BASE_URL=https://bego.com.ht/pagar
